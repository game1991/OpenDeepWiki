# OpenDeepWiki 环境变量示例文件
# 复制此文件为 .env 并填写实际值

# ==========================================
# AI API 配置（必需）
# ==========================================

# AI 对话配置
CHAT_API_KEY=sk-your-openai-api-key-here
ENDPOINT=https://api.openai.com/v1
CHAT_REQUEST_TYPE=OpenAI

# 目录生成 AI 配置（可使用相同或不同的 Key）
WIKI_CATALOG_MODEL=gpt-4o-mini
WIKI_CATALOG_API_KEY=sk-your-catalog-api-key-here
WIKI_CATALOG_ENDPOINT=https://api.openai.com/v1
WIKI_CATALOG_REQUEST_TYPE=OpenAI

# 内容生成 AI 配置
WIKI_CONTENT_MODEL=gpt-4o
WIKI_CONTENT_API_KEY=sk-your-content-api-key-here
WIKI_CONTENT_ENDPOINT=https://api.openai.com/v1
WIKI_CONTENT_REQUEST_TYPE=OpenAI

# AI 处理并发数
WIKI_PARALLEL_COUNT=5

# 支持的语言（逗号分隔）
WIKI_LANGUAGES=en,zh

# ==========================================
# 安全配置（必需）
# ==========================================

# JWT 签名密钥（生产环境必须修改！最少 32 字符）
JWT_SECRET_KEY=your-super-secret-key-min-32-characters-long

# ==========================================
# 数据库配置（使用 MySQL 时启用）
# ==========================================

# MySQL root 密码
# MYSQL_ROOT_PASSWORD=your-root-password

# MySQL 用户密码
# MYSQL_PASSWORD=your-user-password
