# Docker Compose 本地开发环境覆盖配置
# 用法：docker compose -f compose.yaml -f compose.override.yaml up -d

services:
  opendeepwiki:
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      # 开发环境使用更少的资源
      WIKI_PARALLEL_COUNT: "2"

    volumes:
      # 开发模式挂载源码（如需本地开发）
      # - ../src:/app/src:ro

    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 1G

  web:
    environment:
      NODE_ENV: development

    # 开发模式启用热重载
    # command: npm run dev

    deploy:
      resources:
        limits:
          cpus: '0.5'
          memory: 512M
